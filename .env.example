# ──────────────────────────────────────────────
# OpenClaw Inter-Agent Message Queue - Environment
# ──────────────────────────────────────────────
# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# ── Elixir Service ───────────────────────────
IAMQ_HTTP_PORT=18790
IAMQ_WS_PORT=18791
IAMQ_AGENT_TTL_MS=1800000
IAMQ_REAP_INTERVAL_MS=60000
IAMQ_QUEUE_DIR=../queue

# ── OpenClaw Gateway ─────────────────────────
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
IAMQ_GATEWAY_RPC_ENABLED=false

# ── GitHub (for pipeline runner) ─────────────
# Used by gh CLI — typically set via `gh auth login`
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Archgate ─────────────────────────────────
ARCHGATE_CONFIG_PATH=./spec/adr
